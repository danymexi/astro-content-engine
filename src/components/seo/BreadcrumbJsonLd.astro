---
const { items } = Astro.props;
const data = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": items.map((it, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": it.name,
    "item": it.url
  }))
};
---
<script type="application/ld+json" set:html={JSON.stringify(data)} />
